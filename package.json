    "import-prompts:user-more": "node --import tsx scripts/import-prompts-user-more.ts",
    "import-prompts:user-more:preview": "CB_CONTENT_ROOT=content_preview node --import tsx scripts/import-prompts-user-more.ts",
    "import-resources:lta": "node --import tsx scripts/import-resources-legal-text-analytics.ts",
    "import-resources:awesome-legal-data": "node --import tsx scripts/import-resources-awesome-legal-data.ts",
    "import-resources:awesome-legal-data:preview": "CB_CONTENT_ROOT=content_preview node --import tsx scripts/import-resources-awesome-legal-data.ts",
    "import-resources:lawglance": "node --import tsx scripts/import-resources-lawglance.ts",
    "import-resources:lawglance:preview": "CB_CONTENT_ROOT=content_preview node --import tsx scripts/import-resources-lawglance.ts",
