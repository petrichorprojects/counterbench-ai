    "import-prompts:legal-prompts-for-gpt:zip": "node --import tsx scripts/import-prompts-legal-prompts-for-gpt.ts --zip \"/Users/philipprimmler/Downloads/Legal Prompts/legal-prompts-for-gpt-main.zip\"",
    "import-prompts:casepeer-top40": "node --import tsx scripts/import-prompts-casepeer-top40.ts --pdf \"/Users/philipprimmler/Downloads/Legal Prompts/Top 40 ChatGPT Prompts for Lawyers to Boost Productivity.pdf\"",
