    "react-dom": "^19.0.0",
    "remark-gfm": "^4.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@playwright/test": "^1.55.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
