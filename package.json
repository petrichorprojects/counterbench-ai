    "prebuild": "npm run build-search-index",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "import-tools": "node --import tsx scripts/import-tools.ts",
    "import-tools:preview": "CB_CONTENT_ROOT=content_preview node --import tsx scripts/import-tools.ts",
    "qa": "node --import tsx scripts/qa-tools.ts",
    "qa:preview": "CB_CONTENT_ROOT=content_preview node --import tsx scripts/qa-tools.ts",
    "seed-prompts": "node --import tsx scripts/seed-prompts.ts",
