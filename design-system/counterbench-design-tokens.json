    "typography": {
      "font_families": {
        "primary": {
          "name": "SF Pro Display",
          "fallback": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif",
          "weights": [
            300,
            400,
            500,
            600,
            700
          ]
        },
        "secondary": {
          "name": "SF Pro Text",
          "fallback": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif",
          "weights": [
            400,
            500,
            600
          ]
        },
        "mono": {
          "name": "SF Mono",
          "fallback": "'Courier New', Courier, monospace",
          "weights": [
            400,
            500,
            600
          ]
        },
        "serif": {
          "name": "New York",
          "fallback": "Georgia, 'Times New Roman', Times, serif",
          "weights": [
            400,
            500,
            600,
            700
          ],
          "use_case": "Legal documents, formal content"
        }
      },
      "scale": {
        "display_large": {
          "size": "64px",
          "line_height": "72px",
          "weight": 700,
          "letter_spacing": "-0.02em"
        },
        "display": {
          "size": "48px",
          "line_height": "56px",
          "weight": 700,
          "letter_spacing": "-0.01em"
        },
        "h1": {
          "size": "36px",
          "line_height": "44px",
          "weight": 600,
          "letter_spacing": "-0.01em"
        },
        "h2": {
          "size": "30px",
          "line_height": "38px",
          "weight": 600,
          "letter_spacing": "-0.005em"
        },
        "h3": {
          "size": "24px",
          "line_height": "32px",
          "weight": 600,
          "letter_spacing": "0"
        },
        "h4": {
          "size": "20px",
          "line_height": "28px",
          "weight": 600,
          "letter_spacing": "0"
        },
        "body_large": {
          "size": "18px",
          "line_height": "28px",
          "weight": 400,
          "letter_spacing": "0"
        },
        "body": {
          "size": "16px",
          "line_height": "24px",
          "weight": 400,
          "letter_spacing": "0"
        },
        "body_small": {
          "size": "14px",
          "line_height": "20px",
          "weight": 400,
          "letter_spacing": "0"
        },
        "caption": {
          "size": "12px",
          "line_height": "16px",
          "weight": 400,
          "letter_spacing": "0.01em"
        },
        "overline": {
          "size": "11px",
          "line_height": "16px",
          "weight": 600,
          "letter_spacing": "0.08em",
          "text_transform": "uppercase"
        }
      }
    },
    "spacing": {
      "base": 8,
      "scale": {
        "0": "0px",
        "1": "8px",
        "2": "16px",
        "3": "24px",
        "4": "32px",
        "5": "40px",
        "6": "48px",
        "7": "56px",
        "8": "64px",
        "9": "72px",
        "10": "80px",
        "12": "96px",
        "16": "128px",
        "20": "160px",
        "24": "192px"
      },
      "component": {
        "padding_xs": "8px",
        "padding_sm": "12px",
        "padding_md": "16px",
        "padding_lg": "24px",
        "padding_xl": "32px",
        "gap_xs": "4px",
        "gap_sm": "8px",
        "gap_md": "16px",
        "gap_lg": "24px",
        "gap_xl": "32px"
      }
    },
    "layout": {
      "breakpoints": {
        "xs": "0px",
        "sm": "640px",
        "md": "768px",
        "lg": "1024px",
        "xl": "1280px",
        "2xl": "1536px"
      },
      "container": {
        "xs": "100%",
        "sm": "640px",
        "md": "768px",
        "lg": "1024px",
        "xl": "1280px",
        "2xl": "1440px"
      },
      "grid": {
        "columns": 12,
        "gutter": "24px",
        "margin": {
          "mobile": "16px",
          "tablet": "24px",
          "desktop": "48px"
        }
      }
    },
    "border_radius": {
      "none": "0px",
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "2xl": "24px",
      "full": "9999px"
    },
    "shadows": {
      "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
      "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
      "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
      "2xl": "0 25px 50px -12px rgba(0, 0, 0, 0.25)",
      "inner": "inset 0 2px 4px 0 rgba(0, 0, 0, 0.06)"
    },
    "animation": {
      "duration": {
        "instant": "100ms",
        "fast": "200ms",
        "normal": "300ms",
        "slow": "400ms",
        "slower": "600ms"
      },
      "easing": {
        "ease_in": "cubic-bezier(0.4, 0, 1, 1)",
        "ease_out": "cubic-bezier(0, 0, 0.2, 1)",
        "ease_in_out": "cubic-bezier(0.4, 0, 0.2, 1)",
        "spring": "cubic-bezier(0.175, 0.885, 0.32, 1.275)",
        "apple": "cubic-bezier(0.28, 0, 0.12, 1)"
      }
    },
    "accessibility": {
      "wcag_level": "AA",
      "contrast_ratios": {
        "normal_text": "4.5:1",
        "large_text": "3:1",
        "ui_components": "3:1"
      },
      "focus_indicators": {
        "outline_width": "2px",
        "outline_offset": "2px",
        "outline_color": "#3b82f6"
      },
      "touch_targets": {
        "minimum_size": "44px"
      }
    },
    "components": {
      "button": {
        "height": {
          "sm": "32px",
          "md": "40px",
          "lg": "48px"
        },
        "padding": {
          "sm": "0 12px",
          "md": "0 16px",
          "lg": "0 24px"
        },
        "states": [
          "default",
          "hover",
          "active",
          "focus",
          "disabled",
          "loading"
        ]
      },
      "input": {
        "height": {
          "sm": "32px",
          "md": "40px",
          "lg": "48px"
        },
        "padding": "0 12px",
        "states": [
          "default",
          "hover",
          "focus",
          "error",
          "disabled",
          "readonly"
        ]
      },
      "card": {
        "padding": {
          "sm": "16px",
          "md": "24px",
          "lg": "32px"
        },
        "border_radius": "12px",
        "states": [
          "default",
          "hover",
          "active",
          "selected"
        ]
      },
      "modal": {
        "max_width": {
          "sm": "400px",
          "md": "600px",
          "lg": "800px"
        },
        "backdrop": "rgba(0, 0, 0, 0.5)"
      }
    }
